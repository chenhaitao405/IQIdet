{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "run_inference_pipeline: processed valid",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_inference_pipeline.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "QT_QPA_PLATFORM": "offscreen",
        "MPLBACKEND": "Agg"
      },
      "args": [
        "--image-dir",
        "IQIdata/ori/img",
        "--fclip-ckpt",
        "local/fclip67.pth.tar",
        "--gauge-weights",
        "logs/gauge/gauge2/weights/best.pt",
        "--output-dir",
        "outputs/gauge_ocr_retrain_nocorrection",
        "--vis",
        // "--ocr-rec-model-name",
        // "en_PP-OCRv5_mobile_rec",
        "--ocr-rec-model-dir",
        "/home/cht/code/IQIdet/OCRtrain/runs/iqi_en_PP-OCRv5_mobile_rec/inference",
        // "--enable-correction",
        // "--correction-model",
        // "local/weld_orientation_model.pth"
      ]
    },
    {
      "name": "single_valid: HR_1D_0204_test2",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/single_valid.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "QT_QPA_PLATFORM": "offscreen",
        "MPLBACKEND": "Agg"
      },
      "args": [
        "--devices",
        "0",
        "--output_dir",
        "logs/valid/HR_1D_0204_test2",
        "local/config.yaml",
        "local/fclip67.pth.tar",
        "--vis",
        "--fig"
      ]
    },
    {
      "name": "export_text_crops: train max20 correction",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/OCRtrain/scripts/export_text_crops.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "QT_QPA_PLATFORM": "offscreen",
        "MPLBACKEND": "Agg"
      },
      "args": [
        "--dataset-root",
        "local/OCRdatasets/iqi_rec_v2",
        "--subset",
        "train",
        "--gauge-weights",
        "logs/gauge/gauge2/weights/best.pt",
        "--enable-correction",
        "--correction-model",
        "local/weld_orientation_model.pth",
        "--text-det-device",
        "gpu",
        "--text-det-model-name",
        "PP-OCRv5_server_det",
        "--enhance-mode",
        "windowing",
        "--max-images",
        "20",
        "--sample-ratio",
        "0.3"
      ]
    }
  ]
}

{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "run_inference_pipeline: processed valid",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_inference_pipeline.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "QT_QPA_PLATFORM": "offscreen",
        "MPLBACKEND": "Agg"
      },
      "args": [
        "--image-dir",
        "IQIdata/ori/img",
        "--fclip-ckpt",
        "models/fclip67.pth.tar",
        "--gauge-weights",
        "models/guagerotation.pt",
        "--output-dir",
        "outputs/gauge_ocr_retrain_0320_orientation_guagerotation2",
        "--vis",
        "--ocr-det-model-name",
        "PP-OCRv5_server_det",
        "--ocr-det-limit-side-len",
        "960",
        "--ocr-det-limit-type",
        "max",
        // "--ocr-rec-model-name",
        // "en_PP-OCRv5_mobile_rec",
        "--ocr-rec-model-dir",
        "models/OCR_rec_inference_best_accuracy",
        "--enable-ocr-orientation",
        "--ocr-orientation-model",
        "models/ocr_orientation_model.pth",
        "--ocr-orientation-device",
        "cuda:0",
        "--ocr-number-range",
        "6,10-15",
        // "--ocr-orientation-verbose",
        "--enable-correction",
        "--correction-model",
        "models/weld_orientation_model.pth"
      ]
    },
    {
      "name": "run_inference_pipeline: timer20",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_inference_pipeline.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "QT_QPA_PLATFORM": "offscreen",
        "MPLBACKEND": "Agg"
      },
      "args": [
        "--image-dir",
        "IQIdata/ori/img",
        "--max-images",
        "20",
        "--gauge-weights",
        "models/guagerotation.pt",
        "--fclip-ckpt",
        "models/fclip67.pth.tar",
        "--fclip-config",
        "models/fclip_config.yaml",
        "--output-dir",
        "outputs/iqi_debug_timer20",
        "--results-json",
        "iqi_results.json",
        "--stats-json",
        "iqi_stats.json",
        "--timer-json",
        "iqi_timer_stats.json",
        "--debug-timer",
        "--ocr-det-model-name",
        "PP-OCRv5_server_det",
        "--ocr-det-limit-side-len",
        "960",
        "--ocr-det-limit-type",
        "max",
        "--ocr-rec-model-dir",
        "models/OCR_rec_inference_best_accuracy",
        "--enable-ocr-orientation",
        "--ocr-orientation-model",
        "models/ocr_orientation_model.pth",
        "--ocr-orientation-device",
        "cuda:0",
        "--ocr-number-range",
        "6,10-15",
        // "--enable-correction",
        // "--correction-model",
        // "models/weld_orientation_model.pth"
      ]
    },
    {
      "name": "single_valid: HR_1D_0204_test2",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/single_valid.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "QT_QPA_PLATFORM": "offscreen",
        "MPLBACKEND": "Agg"
      },
      "args": [
        "--devices",
        "0",
        "--output_dir",
        "logs/valid/HR_1D_0204_test2",
        "models/fclip_config.yaml",
        "models/fclip67.pth.tar",
        "--vis",
        "--fig"
      ]
    },
    {
      "name": "run_iqi_grade_infer: batch",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_iqi_grade_infer.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "QT_QPA_PLATFORM": "offscreen",
        "MPLBACKEND": "Agg"
      },
      "args": [
        "--image-dir",
        "local/OCRdatasets/cjtest",
        "--gauge-weights",
        "models/guagerotation.pt",
        "--fclip-ckpt",
        "models/fclip67.pth.tar",
        "--fclip-config",
        "models/fclip_config.yaml",
        "--output-json",
        "outputs/iqi_grade_infer_cj/iqi_grade_results.json",
        "--ocr-det-model-name",
        "PP-OCRv5_server_det",
        "--ocr-det-limit-side-len",
        "960",
        "--ocr-det-limit-type",
        "max",
        "--ocr-rec-model-dir",
        "models/OCR_rec_inference_best_accuracy",
        "--enable-ocr-orientation",
        "--ocr-orientation-model",
        "models/ocr_orientation_model.pth",
        "--ocr-orientation-device",
        "cuda:0",
        "--ocr-number-range",
        "6,10-15",
        "--vis-dir",
        "outputs/iqi_grade_infer_cj/vis"
      ]
    },
    {
      "name": "export_text_crops: direct text_det max20",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/OCRtrain/scripts/export_text_crops.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "QT_QPA_PLATFORM": "offscreen",
        "MPLBACKEND": "Agg"
      },
      "args": [
        "--dataset-root",
        "local/OCRdatasets/iqi_rec_textdet_v1",
        "--image-root",
        "IQIdata/ori",
        "--image-root",
        "datasets/images",
        "--text-det-device",
        "gpu",
        "--text-det-model-name",
        "PP-OCRv5_server_det",
        "--enhance-mode",
        "windowing",
        "--max-images",
        "20",
        "--sample-ratio",
        "0.3"
      ]
    }
  ]
}
